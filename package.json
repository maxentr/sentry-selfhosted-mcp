{
  "name": "@maxentr/sentry-selfhosted-mcp",
  "version": "1.1.0",
  "description": "Model Context Protocol server for self-hosted Sentry instances with debugging tools, filtering, raw API access, and stack frame extraction.",
  "license": "MIT",
  "author": "maxentr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxentr/sentry-selfhosted-mcp.git"
  },
  "keywords": [
    "mcp",
    "sentry",
    "self-hosted",
    "debugging",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "sentry-selfhosted-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "check": "biome check",
    "lint": "biome lint",
    "format": "biome format"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@types/node": "^22",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "main": "index.js",
  "bugs": {
    "url": "https://github.com/maxentr/sentry-selfhosted-mcp/issues"
  },
  "homepage": "https://github.com/maxentr/sentry-selfhosted-mcp#readme"
}
