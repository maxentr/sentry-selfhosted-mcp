{
  "name": "@maxentr/sentry-selfhosted-mcp",
  "version": "1.1.0",
  "description": "Model Context Protocol server for self-hosted Sentry instances with debugging tools, filtering, raw API access, and stack frame extraction.",
  "keywords": [
    "debugging",
    "mcp",
    "model-context-protocol",
    "self-hosted",
    "sentry"
  ],
  "homepage": "https://github.com/maxentr/sentry-selfhosted-mcp#readme",
  "bugs": {
    "url": "https://github.com/maxentr/sentry-selfhosted-mcp/issues"
  },
  "license": "MIT",
  "author": "maxentr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxentr/sentry-selfhosted-mcp.git"
  },
  "bin": {
    "sentry-selfhosted-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "prepare": "lefthook install || true && tsc",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "check": "oxlint && oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
